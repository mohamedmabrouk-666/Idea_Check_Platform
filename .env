# ============================================================
# .env — Environment Variables
# NEVER upload this file to GitHub
# Contains all secret keys and credentials
# ============================================================

# Flask secret key — used to sign session cookies and CSRF tokens
# Change this to a long random string in production
SECRET_KEY=your_super_secret_key_change_this_in_production

# MySQL database connection settings
MYSQL_HOST=localhost
MYSQL_USER=root
MYSQL_PASSWORD=yourpassword
MYSQL_DB=similarity_checker

# Setup code — given to university admin to complete first-time setup
# Change this to any code you want before delivering the project
SETUP_CODE=CSE2026
